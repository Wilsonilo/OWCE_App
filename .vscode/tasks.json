{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "iosDeviceName",
      "type": "promptString",
      "description": "Physical iPhone/iPad: use the exact name (before the colon) or the UDID from mlaunch --listdev (see task 'maui: list connected iOS devices')",
      "default": ""
    }
  ],
  "tasks": [
    {
      "label": "maui: list connected iOS devices",
      "type": "shell",
      "command": "MLAUNCH=$(find \"${env:HOME}/.dotnet/packs\" -path \"*Microsoft.iOS.Sdk*/tools/bin/mlaunch\" 2>/dev/null | head -1); if [ -z \"$MLAUNCH\" ]; then echo 'mlaunch not found under ~/.dotnet/packs'; exit 1; fi; \"$MLAUNCH\" --listdev=/tmp/owce-ios-devices.txt && echo '---' && cat /tmp/owce-ios-devices.txt",
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "new" }
    },
    {
      "label": "maui: build iOS Simulator (Debug)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "OWCE.iOS/OWCE.iOS.csproj",
        "-f",
        "net9.0-ios",
        "-c",
        "Debug",
        "-r",
        "iossimulator-arm64",
        "-t:Run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/OWCE",
        "env": {
          "DOTNET_ROOT": "${env:HOME}/.dotnet",
          "PATH": "${env:HOME}/.dotnet:${env:PATH}"
        }
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "maui: run iOS physical device (Debug)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "OWCE.iOS/OWCE.iOS.csproj",
        "-f",
        "net9.0-ios",
        "-c",
        "Debug",
        "-r",
        "ios-arm64",
        "-t:Run",
        "-p:_DeviceName=${input:iosDeviceName}"
      ],
      "options": {
        "cwd": "${workspaceFolder}/OWCE",
        "env": {
          "DOTNET_ROOT": "${env:HOME}/.dotnet",
          "PATH": "${env:HOME}/.dotnet:${env:PATH}"
        }
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "maui: build iOS Simulator (no run)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "OWCE.iOS/OWCE.iOS.csproj",
        "-f",
        "net9.0-ios",
        "-c",
        "Debug",
        "-r",
        "iossimulator-arm64"
      ],
      "options": {
        "cwd": "${workspaceFolder}/OWCE",
        "env": {
          "DOTNET_ROOT": "${env:HOME}/.dotnet",
          "PATH": "${env:HOME}/.dotnet:${env:PATH}"
        }
      },
      "problemMatcher": "$msCompile",
      "group": "build"
    }
  ]
}
