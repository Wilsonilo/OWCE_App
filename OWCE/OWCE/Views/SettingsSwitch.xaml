<?xml version="1.0" encoding="UTF-8"?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    
    x:Class="OWCE.Views.SettingsSwitch"
    WidthRequest="24"
    HeightRequest="24">

    <Border x:Name="RoundedRectangle" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="20" HeightRequest="10" BackgroundColor="Black" StrokeShape="RoundRectangle 5">
        <Grid>
            <Border x:Name="CircleDot" WidthRequest="6" HeightRequest="6" BackgroundColor="White" VerticalOptions="Center" HorizontalOptions="Start" Margin="2,0,0,0" StrokeShape="RoundRectangle 3" />
        </Grid>
    </Border>

</ContentView>
