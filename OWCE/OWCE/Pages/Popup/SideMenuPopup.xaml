<?xml version="1.0" encoding="UTF-8" ?>
<pages:PopupPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Mopups.Pages;assembly=Mopups"
    xmlns:animations="clr-namespace:Mopups.Animations;assembly=Mopups"
    
    x:Class="OWCE.Pages.Popup.SideMenuPopup"
    xmlns:mct="clr-namespace:CommunityToolkit.Maui;assembly=CommunityToolkit.Maui"
    xmlns:popup="clr-namespace:OWCE.Pages.Popup"
    x:DataType="popup:SideMenuPopup"
    >


    <pages:PopupPage.Animation>
        <animations:ScaleAnimation 
            PositionIn="Left"
            PositionOut="Left"
            DurationIn="200"
            DurationOut="200"
            EasingIn="SinOut"
            EasingOut="SinIn"
            ScaleIn="1"
            ScaleOut="1"
            HasBackgroundAnimation="True"/>
    </pages:PopupPage.Animation>

    <Grid
          x:Name="MainGrid"
          BackgroundColor="White"
          HorizontalOptions="Start"
          WidthRequest="500"
          ColumnSpacing="0"
          RowSpacing="12"
          Padding="0,16,0,16"
          Margin="0,0,40,0"
          RowDefinitions="Auto,1,*,1,Auto,Auto">

        <Label Grid.Row="0" Text="{Binding Title}" TextColor="Black" FontAttributes="Bold" FontSize="24" Padding="16,0,16,0" />

        <Image Grid.Row="0" Source="Images/menu_cancel.png" WidthRequest="16" HeightRequest="16" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,16,0">
            <Image.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseMenuTapped" />
            </Image.GestureRecognizers>
        </Image>

        <BoxView Grid.Row="1" Background="#E4E4E4" HeightRequest="1" />

        <!-- Grid.Row 2 is for page specific menu -->

        <BoxView Grid.Row="3" Background="#E4E4E4" HeightRequest="1" />

        <Grid x:Name="SettingsMenuRow" Grid.Row="4" RowDefinitions="Auto" ColumnDefinitions="60,*" ColumnSpacing="0">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSettingsMenuTapped" />
            </Grid.GestureRecognizers>
            <Image Grid.Row="0" Grid.Column="0" InputTransparent="True" Source="Images/menu_settings.png" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center"/>
            <Label Grid.Row="0" Grid.Column="1" InputTransparent="True" Text="Settings" TextColor="Black" FontSize="18" />
        </Grid>

        <Grid x:Name="AboutMenuRow" Grid.Row="5" RowDefinitions="Auto" ColumnDefinitions="60,*" ColumnSpacing="0">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAboutMenuTapped" />
            </Grid.GestureRecognizers>
            <Image Grid.Row="0" Grid.Column="0" InputTransparent="True" Source="Images/settings_info.png" WidthRequest="24" HeightRequest="24" HorizontalOptions="Center"/>
            <Label Grid.Row="0" Grid.Column="1" InputTransparent="True" Text="About this app" TextColor="Black" FontSize="18" />
        </Grid>


    </Grid>

</pages:PopupPage>